# Meta Marketing API — server-side only (never exposed to the browser).
# Copy to .env.local for local dev, and add the same vars in Vercel:
#   Project → Settings → Environment Variables.

# Your access token — a System User token (long-lived) is strongly preferred.
# Needs the ads_management permission on the ad account below.
META_ACCESS_TOKEN=

# Ad account to push into. "act_" prefix is optional (added automatically).
META_AD_ACCOUNT_ID=act_XXXXXXXXXX

# The Facebook Page ads run as (required).
META_PAGE_ID=

# Instagram account id for IG placements (optional).
META_INSTAGRAM_ID=

# Graph API version (optional — defaults to v23.0).
META_API_VERSION=v23.0
